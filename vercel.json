{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.7.2",
            "config": {
                "maxExecutionTime": 30,
                "phpVersion": "8.3",
                "extensions": [
                    "intl",
                    "gd",
                    "bcmath"
                ],
                "includeFiles": [
                    "app/Filament/**",
                    "app/Providers/**",
                    "bootstrap/**",
                    "config/**",
                    "routes/**",
                    "vendor/**",
                    "app/**",
                    "resources/views/**",
                    "storage/**"
                ]
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts|favicon.ico|favicon.png)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ]
}